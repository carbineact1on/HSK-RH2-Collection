<!-- Table -->

  <ThingDef ParentName="TableGatherSpotBase">
    <defName>RH2_FoldingTable1x2c</defName>
    <label>folding table (1x2)</label>
    <graphicData>
      <texPath>Things/Building/Table/FoldingTable2x1</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
      <drawSize>(3,4)</drawSize>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <uiIconScale>0.8</uiIconScale>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <WorkToBuild>750</WorkToBuild>
      <Mass>4</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>3</Beauty>
    </statBases>
    <size>(1,2)</size>
    <costStuffCount>20</costStuffCount>
  </ThingDef>

<!-- Chairs -->

  <ThingDef ParentName="RH2_ArtableFurnitureBase">
    <defName>RH2_FoldingChair</defName>
    <label>folding chair</label>
    <description>A comfortable and attractive folding chair. Can be used at tables, work stations, and elsewhere.</description>
    <graphicData>
      <texPath>Things/Building/Chair/FoldingChair</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.75,1.75)</drawSize>
      <damageData>
        <rectN>(0.25,0.234375,0.5,0.28125)</rectN>
        <rectS>(0.25,0.234375,0.5,0.28125)</rectS>
        <rectE>(0.28125,0.25,0.453125,0.25)</rectE>
        <rectW>(0.28125,0.25,0.453125,0.25)</rectW>
      </damageData>
      <shadowData>
        <volume>(0.23, 0.26, 0.23)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>800</WorkToBuild>
      <Mass>4</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>8</Beauty>
      <Comfort>0.70</Comfort>
    </statBases>
    <socialPropernessMatters>true</socialPropernessMatters>
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
    </stuffCategories>
    <costStuffCount>42</costStuffCount>
    <pathCost>30</pathCost>
    <designationHotKey>Misc7</designationHotKey>
    <fillPercent>0.35</fillPercent>
    <defaultPlacingRot>South</defaultPlacingRot>
    <building>
      <isSittable>true</isSittable>
    </building>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>Tables_B2</li>
    </researchPrerequisites>
  </ThingDef>
  
