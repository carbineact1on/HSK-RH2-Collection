<!-- End Table -->
  <ThingDef ParentName="ArtableFurnitureBase">
    <defName>RH2_LampEndTable</defName>
    <label>modern end table</label>
    <description>A small bedside table with a lamp which makes nearby beds a little bit more comfortable. Must be placed directly adjacent to the head of the bed. Placing more than one end table near the same bed has no effect.</description>
    <surfaceType>Item</surfaceType>
    <graphicData>
      <texPath>Things/Building/Bed/LampEndtable</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
	  <shaderType>CutoutComplex</shaderType>
      <shadowData>
        <volume>(0.3, 0.6, 0.3)</volume>
      </shadowData>
	  <drawSize>(2,2)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>75</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Mass>5</Mass>
      <Flammability>1.0</Flammability>
      <Beauty>5</Beauty>
    </statBases>
    <pathCost>30</pathCost>
    <defaultPlacingRot>South</defaultPlacingRot>
    <costStuffCount>30</costStuffCount>
	<stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>Beds_C2</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Glower">
        <glowRadius>6</glowRadius>
        <glowColor>(255, 241, 201)</glowColor>
      </li>
	
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>20</basePowerConsumption>
      </li>

      <li Class="CompProperties_Facility">
        <statOffsets>
          <Comfort>0.05</Comfort>
        </statOffsets>
        <maxSimultaneous>1</maxSimultaneous>
        <mustBePlacedAdjacentCardinalToBedHead>true</mustBePlacedAdjacentCardinalToBedHead>
      </li>
    </comps>
    <staticSunShadowHeight>0</staticSunShadowHeight>
    <castEdgeShadows>false</castEdgeShadows>
  </ThingDef>
  
