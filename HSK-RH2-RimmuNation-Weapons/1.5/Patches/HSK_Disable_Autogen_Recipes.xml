<?xml version="1.0" encoding="utf-8" ?>
<!-- HSK patch: kill the auto-generated "Build X" recipes from -->
<Patch>

    <!-- Generic umbrella bases (cover most weapons via inheritance) -->
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNBaseMakeableGun"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNBaseMakeableArtless"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNBaseMakeableGrenade"]/recipeMaker</xpath>
    </Operation>

    <!-- Specific category bases (each defines its own inline recipeMaker
         pointing at a specific RN bench — these override the umbrella so
         they need their own removal) -->

    <!-- CQB-class -->
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeablePistol"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableRevolver"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeablePDW"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableShotgun"]/recipeMaker</xpath>
    </Operation>

    <!-- LBW-class (rifles + sharpshooters) -->
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableAKStyle"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableARStyle"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableAssaultRifle"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableBullpup"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableBoltAction"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableDMR"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableAMR"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableMiscRanged"]/recipeMaker</xpath>
    </Operation>

    <!-- HeavyWeapons-class (LMGs, launchers, spacer, grenades) -->
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableMG"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableGrenadeLauncher"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableRocketLauncher"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableOneTimeUseLauncher"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableGrenade"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableGrenadeNL"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableOneTimeUseThrown"]/recipeMaker</xpath>
    </Operation>
    <Operation Class="PatchOperationRemove">
        <success>Always</success>
        <xpath>Defs/ThingDef[@Name="RNMakeableSpacer"]/recipeMaker</xpath>
    </Operation>

</Patch>
