<?xml version="1.0" encoding="utf-8"?>
<!-- MG-42 caliber unification with Parabellum -->
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Parabellum</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>
                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[defName="RNGun_MG42_GPMG"]/verbs/li[verbClass="CombatExtended.Verb_ShootCE"]/defaultProjectile</xpath>
                    <value>
                        <defaultProjectile>Bullet_8mmM_SP</defaultProjectile>
                    </value>
                </li>
                <li Class="PatchOperationReplace">
                    <xpath>Defs/ThingDef[defName="RNGun_MG42_GPMG"]/comps/li[@Class="CombatExtended.CompProperties_AmmoUser"]/ammoSet</xpath>
                    <value>
                        <ammoSet>AmmoSet_8mmM</ammoSet>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>
