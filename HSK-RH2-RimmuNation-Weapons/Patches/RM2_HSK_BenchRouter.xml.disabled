<?xml version="1.0" encoding="utf-8"?>
<!--
  HSK ranged-firearm â†’ RN bench router (UNIVERSAL VERSION).

  Targets standalone RecipeDefs (NOT ThingDef.recipeMaker), so original
  ingredients are preserved â€” only <recipeUsers> is rewritten.

  TIER ORDER MATTERS: CQB runs FIRST, Heavy SECOND, LBW LAST.
  This avoids the SMG/MG substring trap (e.g., BuildHeavySMG matches
  CQB's "SMG" before Heavy ever sees it).

  EXCLUDED (left at original bench):
  - Melee (Sword/Knife/Axe/Mace/Hammer/Spear/Club/Blade)
  - Neolithic / thrown ranged (Bow/Crossbow/Arrow/Throwing/Javelin/Sling)
  - Weapon components / parts (Component/_Parts)
  - Turret crates / turrets (Crate/Turret)
  - Grenades (Grenade)
  - Other explosive throwables (Molotov, bundles, mines, etc.)
  - RH2 weapons (Build_RN â€” already correct)
-->
<Patch>

  <!-- ============================================================
       TIER 1 (FIRST):  CQB  â†’  RNBench_CQB
       Pistols, revolvers, SMGs, PDWs, shotguns, carbines.
       Runs first so SMG/Carbine/Pistol-tagged weapons aren't grabbed
       by Heavy's MG/Heavy/Plasma matchers via substring matching.
       ============================================================ -->
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/RecipeDef[
      not(@Abstract="True")
      and recipeUsers/li[
        text()="WeaponCraftingWorkTable"
        or text()="AdvWeaponCraftingWorkTable"
        or text()="MechWeaponCraftingWorkTable"
        or text()="WeaponsBench"
        or text()="HeavyArmsBench"
        or text()="GunsmithingBench"
      ]
      and not(starts-with(defName, "Build_RN"))
      and not(contains(defName, "Sword"))
      and not(contains(defName, "Knife"))
      and not(contains(defName, "Axe"))
      and not(contains(defName, "Mace"))
      and not(contains(defName, "Hammer"))
      and not(contains(defName, "Spear"))
      and not(contains(defName, "Club"))
      and not(contains(defName, "Blade"))
      and not(contains(defName, "Crossbow"))
      and not(contains(defName, "Bow_"))
      and not(contains(defName, "_Bow"))
      and not(contains(defName, "Arrow"))
      and not(contains(defName, "Melee"))
      and not(contains(defName, "Throwing"))
      and not(contains(defName, "Javelin"))
      and not(contains(defName, "Sling"))
      and not(contains(defName, "Component"))
      and not(contains(defName, "_Parts"))
      and not(contains(defName, "Crate"))
      and not(contains(defName, "Turret"))
      and not(contains(defName, "Armament"))
      and not(contains(defName, "armament"))
      and not(starts-with(defName, "Unmake"))
      and not(contains(defName, "Grenade") and not(contains(defName, "Launcher")))
      and not(contains(defName, "Molotov"))
      and not(contains(defName, "Bundle"))
      and not(contains(defName, "Bottle"))
      and not(contains(defName, "Smine"))
      and not(contains(defName, "_Mine"))
      and not(contains(defName, "Potato"))
      and not(contains(defName, "ARLArcStar"))
      and not(contains(defName, "PWM"))
      and not(contains(defName, "RGO"))
      and not(contains(defName, "Make4kg"))
      and not(contains(defName, "M24Nb"))
      and not(contains(defName, "M24w"))
      and (
        contains(defName, "Pistol")
        or contains(defName, "Revolver")
        or contains(defName, "SMG")
        or contains(defName, "PDW")
        or contains(defName, "Shotgun")
        or contains(defName, "ShortShells")
        or contains(defName, "Carbine")
        or contains(defName, "carbine")
        or contains(defName, "Sidearm")
        or contains(defName, "Submachine")
        or contains(defName, "MachinePistol")
        or contains(defName, "Handgun")
        or contains(defName, "HandGun")
        or contains(defName, "Glock")
        or contains(defName, "DesertEagle")
        or contains(defName, "TT33")
        or contains(defName, "M712")
        or contains(defName, "Vektor")
        or contains(defName, "ParaOrdnance")
      )
    ]/recipeUsers</xpath>
    <value>
      <recipeUsers>
        <li>RNBench_CQB</li>
      </recipeUsers>
    </value>
  </Operation>

  <!-- ============================================================
       TIER 2 (SECOND):  HEAVY  â†’  RNBench_HeavyWeapons
       MGs, launchers, anti-material, cannons. Bare "MG"/"Heavy"/
       "Plasma" REMOVED to avoid false positives on SMGs/rifles.
       Specific MG variants enumerated explicitly.
       ============================================================ -->
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/RecipeDef[
      not(@Abstract="True")
      and recipeUsers/li[
        text()="WeaponCraftingWorkTable"
        or text()="AdvWeaponCraftingWorkTable"
        or text()="MechWeaponCraftingWorkTable"
        or text()="WeaponsBench"
        or text()="HeavyArmsBench"
        or text()="GunsmithingBench"
      ]
      and not(starts-with(defName, "Build_RN"))
      and not(contains(defName, "Sword"))
      and not(contains(defName, "Knife"))
      and not(contains(defName, "Axe"))
      and not(contains(defName, "Mace"))
      and not(contains(defName, "Hammer"))
      and not(contains(defName, "Spear"))
      and not(contains(defName, "Club"))
      and not(contains(defName, "Blade"))
      and not(contains(defName, "Crossbow"))
      and not(contains(defName, "Bow_"))
      and not(contains(defName, "_Bow"))
      and not(contains(defName, "Arrow"))
      and not(contains(defName, "Melee"))
      and not(contains(defName, "Throwing"))
      and not(contains(defName, "Javelin"))
      and not(contains(defName, "Sling"))
      and not(contains(defName, "Component"))
      and not(contains(defName, "_Parts"))
      and not(contains(defName, "Crate"))
      and not(contains(defName, "Turret"))
      and not(contains(defName, "Armament"))
      and not(contains(defName, "armament"))
      and not(starts-with(defName, "Unmake"))
      and not(contains(defName, "Grenade") and not(contains(defName, "Launcher")))
      and not(contains(defName, "Molotov"))
      and not(contains(defName, "Bundle"))
      and not(contains(defName, "Bottle"))
      and not(contains(defName, "Smine"))
      and not(contains(defName, "_Mine"))
      and not(contains(defName, "Potato"))
      and not(contains(defName, "ARLArcStar"))
      and not(contains(defName, "PWM"))
      and not(contains(defName, "RGO"))
      and not(contains(defName, "Make4kg"))
      and not(contains(defName, "M24Nb"))
      and not(contains(defName, "M24w"))
      and (
        contains(defName, "LMG")
        or contains(defName, "HMG")
        or contains(defName, "GPMG")
        or contains(defName, "MMG")
        or contains(defName, "_MG_")
        or contains(defName, "MG0")
        or contains(defName, "MG3")
        or contains(defName, "MG4")
        or contains(defName, "MachineGun")
        or contains(defName, "Incinerator")
        or contains(defName, "Minigun")
        or contains(defName, "Launcher")
        or contains(defName, "Rocket")
        or contains(defName, "Cannon")
        or contains(defName, "Mortar")
        or contains(defName, "Flamethrower")
        or contains(defName, "Spacer")
        or contains(defName, "AntiMaterial")
        or contains(defName, "AntiMateriel")
        or contains(defName, "AMR")
        or contains(defName, "Autocannon")
        or contains(defName, "LAW")
        or contains(defName, "RPG")
        or contains(defName, "RPzB")
        or contains(defName, "PzF")
        or contains(defName, "Bazooka")
        or contains(defName, "M82")
        or contains(defName, "M249")
        or contains(defName, "M79")
        or contains(defName, "M203")
        or contains(defName, "MM1")
        or contains(defName, "Hecate")
        or contains(defName, "OSV96")
        or contains(defName, "PTR127")
        or contains(defName, "XM109")
        or contains(defName, "XM25")
        or contains(defName, "_M200_")
        or contains(defName, "RT20")
        or contains(defName, "VSSK")
        or contains(defName, "SW50")
        or contains(defName, "_PKM")
        or contains(defName, "_PKP")
        or contains(defName, "_RPD")
        or contains(defName, "_RPK")
        or contains(defName, "_RPL")
        or contains(defName, "Huot")
        or contains(defName, "Lewis")
        or contains(defName, "Madsen")
        or contains(defName, "SAW")
      )
    ]/recipeUsers</xpath>
    <value>
      <recipeUsers>
        <li>RNBench_HeavyWeapons</li>
      </recipeUsers>
    </value>
  </Operation>

  <!-- ============================================================
       TIER 3 (LAST):  LBW catch-all  â†’  RNBench_LBW
       Anything still at an HSK weapon bench after Tiers 1 & 2,
       with all exclusions applied.
       ============================================================ -->
  <Operation Class="PatchOperationReplace">
    <success>Always</success>
    <xpath>Defs/RecipeDef[
      not(@Abstract="True")
      and recipeUsers/li[
        text()="WeaponCraftingWorkTable"
        or text()="AdvWeaponCraftingWorkTable"
        or text()="MechWeaponCraftingWorkTable"
        or text()="WeaponsBench"
        or text()="HeavyArmsBench"
        or text()="GunsmithingBench"
      ]
      and not(starts-with(defName, "Build_RN"))
      and not(contains(defName, "Sword"))
      and not(contains(defName, "Knife"))
      and not(contains(defName, "Axe"))
      and not(contains(defName, "Mace"))
      and not(contains(defName, "Hammer"))
      and not(contains(defName, "Spear"))
      and not(contains(defName, "Club"))
      and not(contains(defName, "Blade"))
      and not(contains(defName, "Crossbow"))
      and not(contains(defName, "Bow_"))
      and not(contains(defName, "_Bow"))
      and not(contains(defName, "Arrow"))
      and not(contains(defName, "Melee"))
      and not(contains(defName, "Throwing"))
      and not(contains(defName, "Javelin"))
      and not(contains(defName, "Sling"))
      and not(contains(defName, "Component"))
      and not(contains(defName, "_Parts"))
      and not(contains(defName, "Crate"))
      and not(contains(defName, "Turret"))
      and not(contains(defName, "Armament"))
      and not(contains(defName, "armament"))
      and not(starts-with(defName, "Unmake"))
      and not(contains(defName, "Grenade") and not(contains(defName, "Launcher")))
      and not(contains(defName, "Molotov"))
      and not(contains(defName, "Bundle"))
      and not(contains(defName, "Bottle"))
      and not(contains(defName, "Smine"))
      and not(contains(defName, "_Mine"))
      and not(contains(defName, "Potato"))
      and not(contains(defName, "ARLArcStar"))
      and not(contains(defName, "PWM"))
      and not(contains(defName, "RGO"))
      and not(contains(defName, "Make4kg"))
      and not(contains(defName, "M24Nb"))
      and not(contains(defName, "M24w"))
    ]/recipeUsers</xpath>
    <value>
      <recipeUsers>
        <li>RNBench_LBW</li>
      </recipeUsers>
    </value>
  </Operation>

</Patch>
