<?xml version="1.0" encoding="utf-8" ?>
<!--
    HSK patch: add 6x24mm Charged ammo recipes to RH2 RN benches.

    Why?
    6x24mm Charged is a HSK-CE-active light charged caliber used by:
      - Wolfein Charge Rapid-Fire Pistol
      - Wolfein Charge SMG
      - Wolfein Taser Gun (charged taser cells via Wolfein_AmmoSet_TaserCharged)

    By default the ammo recipes (MakeAmmo_6x24mmCharged + _AP + _Ion variants)
    only load onto HSK's standard ammo bench via the ChargeAmmoRecipeBase
    parent. RH2 RN-bench players couldn't craft the cartridges there.

    Patch adds the 3 RN benches to each variant's recipeUsers list.
    Additive — HSK ammo bench routing preserved.

    Gated by RH2 RimmuNation² Weapons being active. If the mod isn't
    loaded, the operation is silently skipped via <success>Always</success>.
-->
<Patch>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>[RH2] Rimmu-Nation² - Weapons</li>
        </mods>
        <match Class="PatchOperationSequence">
            <success>Always</success>
            <operations>

                <li Class="PatchOperationAdd">
                    <xpath>Defs/RecipeDef[defName="MakeAmmo_6x24mmCharged"]/recipeUsers</xpath>
                    <value>
                        <li>RNBench_CQB</li>
                        <li>RNBench_LBW</li>
                        <li>RNBench_HeavyWeapons</li>
                    </value>
                </li>

                <li Class="PatchOperationAdd">
                    <xpath>Defs/RecipeDef[defName="MakeAmmo_6x24mmCharged_AP"]/recipeUsers</xpath>
                    <value>
                        <li>RNBench_CQB</li>
                        <li>RNBench_LBW</li>
                        <li>RNBench_HeavyWeapons</li>
                    </value>
                </li>

                <li Class="PatchOperationAdd">
                    <xpath>Defs/RecipeDef[defName="MakeAmmo_6x24mmCharged_Ion"]/recipeUsers</xpath>
                    <value>
                        <li>RNBench_CQB</li>
                        <li>RNBench_LBW</li>
                        <li>RNBench_HeavyWeapons</li>
                    </value>
                </li>

            </operations>
        </match>
    </Operation>

</Patch>
