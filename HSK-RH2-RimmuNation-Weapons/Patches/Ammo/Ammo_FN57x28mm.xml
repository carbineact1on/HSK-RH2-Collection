<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationTest">
        <xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_FN57x28mm"]</xpath>
        <success>Invert</success>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs</xpath>
        <value>

	<ThingCategoryDef>
		<defName>AmmoFN57x28mm</defName>
		<label>FN 5.7x28mm</label>
		<parent>AmmoPistols</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberPistol</iconPath>
	</ThingCategoryDef>

	<!-- ==================== AmmoSet ========================== -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_FN57x28mm</defName>
		<label>FN 5.7x28mm</label>
		<ammoTypes>
			<Ammo_FN57x28mm_FMJ>Bullet_FN57x28mm_FMJ</Ammo_FN57x28mm_FMJ>
			<Ammo_FN57x28mm_AP>Bullet_FN57x28mm_AP</Ammo_FN57x28mm_AP>
			<Ammo_FN57x28mm_HP>Bullet_FN57x28mm_HP</Ammo_FN57x28mm_HP>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- ==================== Ammo ========================== -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="FN57x29mmBase" ParentName="SmallAmmoBase" Abstract="True">
		<description>This high-velocity handgun cartridge was specifically designed for military personnel to defeat body armor.</description>
		<statBases>
			<Mass>0.008</Mass>
			<Bulk>0.01</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting</li>
		</tradeTags>
		<thingCategories>
			<li>AmmoFN57x28mm</li>
		</thingCategories>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="FN57x29mmBase">
		<defName>Ammo_FN57x28mm_FMJ</defName>
		<label>FN 5.7x28mm (FMJ)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/FMJ</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>FullMetalJacket</ammoClass>
		<cookOffProjectile>Bullet_FN57x28mm_FMJ</cookOffProjectile>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="FN57x29mmBase">
		<defName>Ammo_FN57x28mm_AP</defName>
		<label>FN 5.7x28mm (AP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/AP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>ArmorPiercing</ammoClass>
		<cookOffProjectile>Bullet_FN57x28mm_AP</cookOffProjectile>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="FN57x29mmBase">
		<defName>Ammo_FN57x28mm_HP</defName>
		<label>FN 5.7x28mm (HP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/HP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>HollowPoint</ammoClass>
		<cookOffProjectile>Bullet_FN57x28mm_HP</cookOffProjectile>
	</ThingDef>

	<!-- ================== Projectiles ================== -->

	<ThingDef Name="BaseFN57x28mmBullet" ParentName="BaseBulletCE" Abstract="true">
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Bullet</damageDef>
			<speed>129</speed>
			<dropsCasings>true</dropsCasings>
			<casingMoteDefname>Fleck_PistolAmmoCasings</casingMoteDefname>
			<casingFilthDefname>Filth_PistolAmmoCasings</casingFilthDefname>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseFN57x28mmBullet">
		<defName>Bullet_FN57x28mm_FMJ</defName>
		<label>FN 5.7mm bullet (FMJ)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>9</damageAmountBase>
			<armorPenetrationSharp>5</armorPenetrationSharp>
			<armorPenetrationBlunt>10.980</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseFN57x28mmBullet">
		<defName>Bullet_FN57x28mm_AP</defName>
		<label>FN 5.7mm bullet (AP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>6</damageAmountBase>
			<armorPenetrationSharp>10</armorPenetrationSharp>
			<armorPenetrationBlunt>10.980</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="BaseFN57x28mmBullet">
		<defName>Bullet_FN57x28mm_HP</defName>
		<label>FN 5.7mm bullet (HP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>12</damageAmountBase>
			<armorPenetrationSharp>3</armorPenetrationSharp>
			<armorPenetrationBlunt>10.980</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- ==================== Recipes ========================== -->

	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_FN57x28mm_FMJ</defName>
		<label>make FN 5.7x28mm (FMJ) cartridge x100</label>
		<description>Craft 100 FN 5.7x28mm (FMJ) cartridges.</description>
		<jobString>Making FN 5.7x28mm (FMJ) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>3</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_FN57x28mm_FMJ>100</Ammo_FN57x28mm_FMJ>
		</products>
	</RecipeDef>
	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_FN57x28mm_AP</defName>
		<label>make FN 5.7x28mm (AP) cartridge x100</label>
		<description>Craft 100 FN 5.7x28mm (AP) cartridges.</description>
		<jobString>Making FN 5.7x28mm (AP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>4</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>USLDHBar</li>
						<li>Ceramic</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>USLDHBar</li>
				<li>Ceramic</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_FN57x28mm_AP>100</Ammo_FN57x28mm_AP>
		</products>
	</RecipeDef>
	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_FN57x28mm_HP</defName>
		<label>make FN 5.7x28mm (HP) cartridge x100</label>
		<description>Craft 100 FN 5.7x28mm (HP) cartridges.</description>
		<jobString>Making FN 5.7x28mm (HP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>5</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>HeavyBar</li>
					</categories>
					<thingDefs>
						<li>Plastic</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>3</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Plastic</li>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_FN57x28mm_HP>100</Ammo_FN57x28mm_HP>
		</products>
	</RecipeDef>

        </value>
      </li>
    </operations>
  </Operation>
</Patch>
