<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationTest">
        <xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_32ACP"]</xpath>
        <success>Invert</success>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs</xpath>
        <value>

	<ThingCategoryDef>
		<defName>Ammo32ACP</defName>
		<label>.32 ACP</label>
		<parent>AmmoPistols</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberPistol</iconPath>
	</ThingCategoryDef>

	<!-- ==================== AmmoSet ========================== -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_32ACP</defName>
		<label>.32 ACP</label>
		<ammoTypes>
			<Ammo_32ACP_FMJ>Bullet_32ACP_FMJ</Ammo_32ACP_FMJ>
			<Ammo_32ACP_AP>Bullet_32ACP_AP</Ammo_32ACP_AP>
			<Ammo_32ACP_HP>Bullet_32ACP_HP</Ammo_32ACP_HP>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- ==================== Ammo ========================== -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="32ACPBase" ParentName="SmallAmmoBase" Abstract="True">
		<description>Low caliber handgun cartridge lacking in stopping power.</description>
		<statBases>
			<Mass>0.007</Mass>
			<Bulk>0.01</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting</li>
		</tradeTags>
		<thingCategories>
			<li>Ammo32ACP</li>
		</thingCategories>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="32ACPBase">
		<defName>Ammo_32ACP_FMJ</defName>
		<label>.32 ACP (FMJ)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/FMJ</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>FullMetalJacket</ammoClass>
		<cookOffProjectile>Bullet_32ACP_FMJ</cookOffProjectile>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="32ACPBase">
		<defName>Ammo_32ACP_AP</defName>
		<label>.32 ACP (AP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/AP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>ArmorPiercing</ammoClass>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="32ACPBase">
		<defName>Ammo_32ACP_HP</defName>
		<label>.32 ACP (HP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/HP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>HollowPoint</ammoClass>
	</ThingDef>

	<!-- ================== Projectiles ================== -->

	<ThingDef Name="Base32ACPBullet" ParentName="BaseBulletCE" Abstract="true">
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Bullet</damageDef>
			<speed>76</speed>
			<dropsCasings>true</dropsCasings>
			<casingMoteDefname>Fleck_PistolAmmoCasings</casingMoteDefname>
			<casingFilthDefname>Filth_PistolAmmoCasings</casingFilthDefname>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base32ACPBullet">
		<defName>Bullet_32ACP_FMJ</defName>
		<label>.32 ACP bullet (FMJ)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>8</damageAmountBase>
			<armorPenetrationSharp>3</armorPenetrationSharp>
			<armorPenetrationBlunt>4.6</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base32ACPBullet">
		<defName>Bullet_32ACP_AP</defName>
		<label>.32 ACP bullet (AP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>5</damageAmountBase>
			<armorPenetrationSharp>6</armorPenetrationSharp>
			<armorPenetrationBlunt>4.6</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base32ACPBullet">
		<defName>Bullet_32ACP_HP</defName>
		<label>.32 ACP bullet (HP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>10</damageAmountBase>
			<armorPenetrationSharp>2</armorPenetrationSharp>
			<armorPenetrationBlunt>4.6</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- ==================== Recipes ========================== -->

	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_32ACP_FMJ</defName>
		<label>make .32 ACP (FMJ) cartridge x100</label>
		<description>Craft 100 .32 ACP (FMJ) cartridges.</description>
		<jobString>Making .32 ACP (FMJ) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>3</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_32ACP_FMJ>100</Ammo_32ACP_FMJ>
		</products>
	</RecipeDef>

	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_32ACP_AP</defName>
		<label>make .32 ACP (AP) cartridge x100</label>
		<description>Craft 100 .32 ACP (AP) cartridges.</description>
		<jobString>Making .32 ACP (AP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>4</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>5</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>USLDHBar</li>
						<li>Ceramic</li>
					</categories>
				</filter>
				<count>2</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>USLDHBar</li>
				<li>Ceramic</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_32ACP_AP>100</Ammo_32ACP_AP>
		</products>
	</RecipeDef>

	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_32ACP_HP</defName>
		<label>make .32 ACP (HP) cartridge x100</label>
		<description>Craft 100 .32 ACP (HP) cartridges.</description>
		<jobString>Making .32 ACP (HP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>5</Crafting>
		</skillRequirements>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>HeavyBar</li>
					</categories>
					<thingDefs>
						<li>Plastic</li>
					</thingDefs>
				</filter>
				<count>3</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>3</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>2</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Plastic</li>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_32ACP_HP>100</Ammo_32ACP_HP>
		</products>
	</RecipeDef>

        </value>
      </li>
    </operations>
  </Operation>
</Patch>
