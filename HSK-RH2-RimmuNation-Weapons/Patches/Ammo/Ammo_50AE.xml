<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationTest">
        <xpath>Defs/CombatExtended.AmmoSetDef[defName="AmmoSet_50AE"]</xpath>
        <success>Invert</success>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs</xpath>
        <value>

	<ThingCategoryDef>
		<defName>Ammo50AE</defName>
		<label>.50 AE</label>
		<parent>AmmoPistols</parent>
		<iconPath>UI/Icons/ThingCategories/CaliberPistol</iconPath>
	</ThingCategoryDef>

	<!-- ==================== AmmoSet ========================== -->

	<CombatExtended.AmmoSetDef>
		<defName>AmmoSet_50AE</defName>
		<label>.50 AE</label>
		<ammoTypes>
			<Ammo_50AE_FMJ>Bullet_50AE_FMJ</Ammo_50AE_FMJ>
			<Ammo_50AE_AP>Bullet_50AE_AP</Ammo_50AE_AP>
			<Ammo_50AE_HP>Bullet_50AE_HP</Ammo_50AE_HP>
		</ammoTypes>
	</CombatExtended.AmmoSetDef>

	<!-- ==================== Ammo ========================== -->

	<ThingDef Class="CombatExtended.AmmoDef" Name="50AEBase" ParentName="AmmoBase" Abstract="True">
		<description>This high-powered cartridge is one of the largest calibers found in handguns.</description>
		<statBases>
			<Mass>0.029</Mass>
			<Bulk>0.02</Bulk>
		</statBases>
		<tradeTags>
			<li>CE_AutoEnableTrade</li>
			<li>CE_AutoEnableCrafting</li>
		</tradeTags>
		<thingCategories>
			<li>Ammo50AE</li>
		</thingCategories>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="50AEBase">
		<defName>Ammo_50AE_FMJ</defName>
		<label>.50 AE (FMJ)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/FMJ</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>FullMetalJacket</ammoClass>
		<cookOffProjectile>Bullet_50AE_FMJ</cookOffProjectile>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="50AEBase">
		<defName>Ammo_50AE_AP</defName>
		<label>.50 AE (AP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/AP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>ArmorPiercing</ammoClass>
		<cookOffProjectile>Bullet_50AE_AP</cookOffProjectile>
	</ThingDef>

	<ThingDef Class="CombatExtended.AmmoDef" ParentName="50AEBase">
		<defName>Ammo_50AE_HP</defName>
		<label>.50 AE (HP)</label>
		<graphicData>
			<texPath>Things/Ammo/Pistol/HP</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<ammoClass>HollowPoint</ammoClass>
		<cookOffProjectile>Bullet_50AE_HP</cookOffProjectile>
	</ThingDef>

	<!-- ================== Projectiles ================== -->

	<ThingDef Name="Base50AEBullet" ParentName="BaseBulletCE" Abstract="true">
		<graphicData>
			<texPath>Things/Projectile/Bullet_Big</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageDef>Bullet</damageDef>
			<speed>98</speed>
			<dropsCasings>true</dropsCasings>
			<casingMoteDefname>Fleck_PistolAmmoCasings</casingMoteDefname>
			<casingFilthDefname>Filth_PistolAmmoCasings</casingFilthDefname>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base50AEBullet">
		<defName>Bullet_50AE_FMJ</defName>
		<label>.50 AE bullet (FMJ)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>19</damageAmountBase>
			<armorPenetrationSharp>6.5</armorPenetrationSharp>
			<armorPenetrationBlunt>39.36</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base50AEBullet">
		<defName>Bullet_50AE_AP</defName>
		<label>.50 AE bullet (AP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>12</damageAmountBase>
			<armorPenetrationSharp>13</armorPenetrationSharp>
			<armorPenetrationBlunt>39.36</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<ThingDef ParentName="Base50AEBullet">
		<defName>Bullet_50AE_HP</defName>
		<label>.50 AE bullet (HP)</label>
		<projectile Class="CombatExtended.ProjectilePropertiesCE">
			<damageAmountBase>24</damageAmountBase>
			<armorPenetrationSharp>3.5</armorPenetrationSharp>
			<armorPenetrationBlunt>39.36</armorPenetrationBlunt>
		</projectile>
	</ThingDef>

	<!-- ==================== Recipes ========================== -->

	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_50AE_FMJ</defName>
		<label>make .50 AE (FMJ) cartridge x60</label>
		<description>Craft 60 .50 AE (FMJ) cartridges.</description>
		<jobString>Making .50 AE (FMJ) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>8</Crafting>
		</skillRequirements>
		<researchPrerequisite>Range_C2</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>18</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>8</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_50AE_FMJ>60</Ammo_50AE_FMJ>
		</products>
	</RecipeDef>
	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_50AE_AP</defName>
		<label>make .50 AE (AP) cartridge x60</label>
		<description>Craft 60 .50 AE (AP) cartridges.</description>
		<jobString>Making .50 AE (AP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>8</Crafting>
		</skillRequirements>
		<researchPrerequisite>Range_C2</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>USLDBar</li>
					</categories>
				</filter>
				<count>18</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>USLDHBar</li>
						<li>Ceramic</li>
					</categories>
				</filter>
				<count>8</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>USLDBar</li>
				<li>USLDHBar</li>
				<li>Ceramic</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_50AE_AP>60</Ammo_50AE_AP>
		</products>
	</RecipeDef>
	<RecipeDef ParentName="AmmoRecipeBase">
		<defName>MakeAmmo_50AE_HP</defName>
		<label>make .50 AE (HP) cartridge x60</label>
		<description>Craft 60 .50 AE (HP) cartridges.</description>
		<jobString>Making .50 AE (HP) cartridges.</jobString>
		<workSkill>Crafting</workSkill>
		<workSkillLearnFactor>0.8</workSkillLearnFactor>
		<skillRequirements>
			<Crafting>8</Crafting>
		</skillRequirements>
		<researchPrerequisite>Range_C2</researchPrerequisite>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>SLDBar</li>
						<li>HeavyBar</li>
					</categories>
					<thingDefs>
						<li>Plastic</li>
					</thingDefs>
				</filter>
				<count>10</count>
			</li>
			<li>
				<filter>
					<categories>
						<li>HeavyBar</li>
					</categories>
				</filter>
				<count>8</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>Powder</li>
					</thingDefs>
				</filter>
				<count>5</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Plastic</li>
				<li>Powder</li>
			</thingDefs>
			<categories>
				<li>SLDBar</li>
				<li>HeavyBar</li>
			</categories>
		</fixedIngredientFilter>
		<products>
			<Ammo_50AE_HP>60</Ammo_50AE_HP>
		</products>
	</RecipeDef>

        </value>
      </li>
    </operations>
  </Operation>
</Patch>
