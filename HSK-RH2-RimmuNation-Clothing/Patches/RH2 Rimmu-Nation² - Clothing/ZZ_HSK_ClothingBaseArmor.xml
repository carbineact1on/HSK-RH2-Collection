<?xml version="1.0" encoding="utf-8"?>
<!-- HSK: add baseline ArmorRating_Sharp / ArmorRating_Blunt to all RH2 -->
<Patch>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[(starts-with(defName, "RNApparel_") or starts-with(defName, "RHApparel_")) and not(statBases/ArmorRating_Sharp)]/statBases</xpath>
        <value>
            <ArmorRating_Sharp>0.05</ArmorRating_Sharp>
            <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
        </value>
    </Operation>
</Patch>
